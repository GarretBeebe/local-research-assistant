# Ollama — Phase 1: all three default to the same instance.
# Phase 2: point each to a dedicated instance to prevent model-load churn.
#   OLLAMA_PLANNER_URL — planner + synthesizer (qwen2.5:14b / qwen2.5:7b)
#   OLLAMA_RESEARCHER_URL — researcher workers (llama3.1:8b)
OLLAMA_URL=http://localhost:11434
OLLAMA_PLANNER_URL=http://localhost:11434
OLLAMA_RESEARCHER_URL=http://localhost:11434

# rag-system connection — token must match RAG_INTERNAL_TOKEN in your rag-system .env
RAG_BASE_URL=http://localhost:8000
RAG_INTERNAL_TOKEN=your-rag-internal-token-here

# local-graph-rag connection — defaults to port 8001 to avoid conflict with rag-system (8000).
# Set API_PORT=8001 in local-graph-rag/.env when running both services simultaneously.
# Leave GRAPH_RAG_API_KEY empty only if ALLOW_INSECURE_LOCALONLY=true in local-graph-rag.
GRAPH_RAG_BASE_URL=http://localhost:8001
GRAPH_RAG_API_KEY=your-graph-rag-api-key-here

# Resource governor — max parallel researchers; serialize when free RAM < threshold
MAX_CONCURRENT_RESEARCHERS=2
MEMORY_PRESSURE_THRESHOLD_MB=6144

# Optional: set to true to log full chunk text instead of 200-char excerpts
DEBUG_LOG_FULL_PAYLOADS=false
