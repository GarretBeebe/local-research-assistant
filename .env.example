# Ollama — Phase 1: all three default to the same instance.
# Phase 2: point each to a dedicated instance to prevent model-load churn.
#   OLLAMA_PLANNER_URL — planner + synthesizer (qwen2.5:14b / qwen2.5:7b)
#   OLLAMA_RESEARCHER_URL — researcher workers (llama3.1:8b)
OLLAMA_URL=http://localhost:11434
OLLAMA_PLANNER_URL=http://localhost:11434
OLLAMA_RESEARCHER_URL=http://localhost:11434

# rag-system connection — token must match RAG_INTERNAL_TOKEN in your rag-system .env
RAG_BASE_URL=http://localhost:8000
RAG_INTERNAL_TOKEN=your-rag-internal-token-here

# local-graph-rag connection — defaults to port 8001 to avoid conflict with rag-system (8000).
# Set API_PORT=8001 in local-graph-rag/.env when running both services simultaneously.
# Leave GRAPH_RAG_API_KEY empty only if ALLOW_INSECURE_LOCALONLY=true in local-graph-rag.
GRAPH_RAG_BASE_URL=http://localhost:8001
GRAPH_RAG_API_KEY=your-graph-rag-api-key-here

# Resource governor — max parallel researchers; serialize when free RAM < threshold
MAX_CONCURRENT_RESEARCHERS=2
MEMORY_PRESSURE_THRESHOLD_MB=6144

# Optional: set to true to log full chunk text instead of 200-char excerpts
DEBUG_LOG_FULL_PAYLOADS=false

# ── Web server (Phase 4) ───────────────────────────────────────────────────────

# Bind address and port for the FastAPI server
HOST=127.0.0.1
PORT=8080

# Security mode — choose one:
#   ALLOW_INSECURE_LOCALONLY=true  →  binds to loopback only; no API bearer token required
#   API_KEY=<32+ char secret>      →  bearer token for /v1/* API endpoints
# Both can be set simultaneously. Neither is a hard startup error.
# Setting neither is a hard startup error (fails closed).
ALLOW_INSECURE_LOCALONLY=true
API_KEY=

# Browser UI password (bcrypt hash). Generate with:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=

# Trusted reverse proxy IPs (comma-separated). Used to extract real client IP from
# X-Forwarded-For and HTTPS status from X-Forwarded-Proto.
# Leave empty when running without a proxy (direct bind).
TRUSTED_PROXY_IPS=

# Staging directory for uploaded documents (before indexing).
# Leave empty to use ./staging relative to the project root.
UPLOAD_STAGING_DIR=

# Document ingestion endpoints (TODO: confirm signatures with sibling services)
# RAG_INGEST_URL=http://localhost:8000/v1/ingest
# GRAPH_RAG_INGEST_URL=http://localhost:8001/v1/ingest
